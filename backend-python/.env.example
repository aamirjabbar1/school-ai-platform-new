# ══════════════════════════════════════════════════════════════════════════════
#  School AI Platform — environment variables template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

PORT=8000
ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/school_ai_db
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:YOUR_DB_PASSWORD@localhost:5432/school_ai_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=YOUR_MINIO_SECRET_KEY
MINIO_BUCKET=school-documents
MINIO_SECURE=false

# ─── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=YOUR_JWT_SECRET_HEX_64_CHARS
JWT_EXPIRES_DAYS=7

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
# Used for chat responses + query classification
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-6

# ─── Google Gemini (Document parsing) ─────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
# Used for PDF/DOCX text + figure extraction (vision)
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-pro

# ─── OpenAI (Embeddings) ──────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Used for text-embedding-3-large (3072 dimensions)
OPENAI_API_KEY=sk-...

# ─── School ───────────────────────────────────────────────────────────────────
SCHOOL_NAME=LSS Bot
SCHOOL_TAGLINE=Excellence in Education
FRONTEND_URL=http://localhost:3000

# ─── Files ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
