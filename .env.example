# ══════════════════════════════════════════════════════════════════════════════
#  School AI Platform — environment variables
#  Copy this file to .env and fill in every value marked REQUIRED.
#  Variables with a default in docker-compose.yml are marked OPTIONAL.
# ══════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_NAME=school_ai_db          # OPTIONAL  (default: school_ai_db)
DB_USER=postgres              # OPTIONAL  (default: postgres)
DB_PASSWORD=                  # REQUIRED  — choose a strong password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Internal Docker service URL — do not change unless you use an external Redis
REDIS_URL=redis://redis:6379/0   # OPTIONAL  (default: redis://redis:6379/0)

# ─── MinIO object storage ─────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin    # OPTIONAL  (default: minioadmin)
MINIO_ROOT_PASSWORD=          # REQUIRED  — choose a strong password

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -hex 32
JWT_SECRET=                   # REQUIRED

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=            # REQUIRED  — get from console.anthropic.com
AI_MODEL=claude-opus-4-6      # OPTIONAL  (default: claude-opus-4-6)

# ─── School branding ──────────────────────────────────────────────────────────
SCHOOL_NAME=My School         # OPTIONAL
SCHOOL_TAGLINE=Excellence in Education   # OPTIONAL
# In production set this to your real domain, e.g. https://school.example.com
FRONTEND_URL=http://localhost  # OPTIONAL  (default: http://localhost)
